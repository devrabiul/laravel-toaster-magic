{
  "name": "laravel-toaster-magic-docs",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Documentation website for the Laravel Toaster Magic notification package.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
